<!--  CSS in style.css + landing.css (landing.css restyles this page only)
      JS in main.js file
  -->
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RoomieFinder – Find Your Perfect Roommate &amp; Home</title>
    <link
        href="https://fonts.goo gleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap"
        rel="stylesheet" />
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/auth.css">
    <link rel="stylesheet" href="/css/landing.css">
    <!-- <link rel="stylesheet" href="../public/css/landing.css"> -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
</head>

<body>
<div class="lp-wrap">

    <!-- NAV -->
    <nav class="lp-nav">
        <div class="lp-brand">
            <div class="lp-brand-mark">R</div>
            RoomieFinder
        </div>
        <ul class="lp-nav-links">
            <li><a href="/listings">Browse Rooms</a></li>
            <li><a href="#roommates">Find Roommates</a></li>
            <li><a href="#how">How it Works</a></li>
            <li><a href="#reviews">Reviews</a></li>
        </ul>
        <div class="lp-nav-auth">

    <% if(user) { %>

        <span class="lp-hi">Hi, <%= user.fullname %></span>
        <a href="/logout">
            <button class="lp-btn-getstarted">Logout →</button>
        </a>

    <% } else { %>

        <button class="lp-btn-signin" id="openLogin">Sign In</button>
        <button class="lp-btn-getstarted" id="openRegister">Get Started</button>

    <% } %>

        </div>
    </nav>

    <!-- HERO -->
    <section class="lp-hero">
        <div class="reveal">
            <div class="lp-pill">
                <i class="fa-solid fa-people-roof"></i>
                Over 50,000 happy roommates matched
            </div>

            <h1 class="lp-h1">
                Find Your Perfect<br>
                <span class="accent">Roommate</span> &amp; Home
            </h1>

            <p class="lp-sub">
                Browse verified listings, connect with compatible roommates, and move into a space
                that fits your lifestyle and budget.
            </p>

            <div class="lp-searchbar">
                <div class="lp-search-field">
                    <i class="fa-solid fa-location-dot"></i>
                    <input type="text" placeholder="City or neighborhood…">
                </div>
                <div class="lp-search-field">
                    <i class="fa-solid fa-dollar-sign"></i>
                    <input type="text" placeholder="Budget / mo">
                </div>
                <div class="lp-search-field">
                    <i class="fa-solid fa-house"></i>
                    <select>
                        <option value="">Room type</option>
                        <option value="private">Private room</option>
                        <option value="shared">Shared room</option>
                        <option value="studio">Studio</option>
                    </select>
                </div>
                <button type="button" class="lp-search-btn"><i class="fa-solid fa-magnifying-glass"></i> Search</button>
            </div>

            <div class="lp-cta-row">
                <a href="/listings"><button class="lp-btn-primary">Find a Room</button></a>
                <a href="#roommates"><button class="lp-btn-secondary">Find a Roommate</button></a>
            </div>
        </div>

        <div class="lp-hero-img-wrap reveal">
            <img class="lp-hero-img" src="https://picsum.photos/seed/roomiefinder-living/900/1000.webp" alt="Modern living room interior">

            <div class="lp-float-card lp-float-rating">
                <div class="lp-float-icon"><i class="fa-solid fa-star"></i></div>
                <div>
                    <div class="lp-float-num">4.9 / 5</div>
                    <div class="lp-float-label">User rating</div>
                </div>
            </div>

            <div class="lp-float-card lp-float-listings">
                <div class="lp-float-icon"><i class="fa-solid fa-users"></i></div>
                <div>
                    <div class="lp-float-num">12,400+</div>
                    <div class="lp-float-label">Active listings</div>
                </div>
            </div>
        </div>
    </section>

    <!-- HOW IT WORKS -->
    <section id="how" class="lp-how-section">
        <div class="container">
            <div class="lp-section-head reveal">
                <div class="lp-eyebrow"><i class="fa-solid fa-bolt"></i> Simple process</div>
                <h2 class="lp-section-title">How RoomieFinder Works</h2>
                <p class="lp-section-sub">From creating your profile to moving in — we make finding your
                    perfect living situation easy.</p>
            </div>

            <div class="lp-how-grid">
                <div class="lp-how-card reveal">
                    <div class="lp-how-num">01</div>
                    <div class="lp-how-arrow"><i class="fa-solid fa-chevron-right"></i></div>
                    <div class="lp-how-icon"><i class="fa-solid fa-user-plus"></i></div>
                    <div class="lp-how-title">Create Your Profile</div>
                    <p class="lp-how-desc">Tell us about your lifestyle, habits, and preferences so we can
                        match you with the right people.</p>
                </div>
                <div class="lp-how-card reveal">
                    <div class="lp-how-num">02</div>
                    <div class="lp-how-arrow"><i class="fa-solid fa-chevron-right"></i></div>
                    <div class="lp-how-icon"><i class="fa-solid fa-magnifying-glass"></i></div>
                    <div class="lp-how-title">Browse Listings</div>
                    <p class="lp-how-desc">Explore verified room listings filtered by budget, location, and
                        roommate compatibility score.</p>
                </div>
                <div class="lp-how-card reveal">
                    <div class="lp-how-num">03</div>
                    <div class="lp-how-arrow"><i class="fa-solid fa-chevron-right"></i></div>
                    <div class="lp-how-icon"><i class="fa-solid fa-comment"></i></div>
                    <div class="lp-how-title">Connect &amp; Chat</div>
                    <p class="lp-how-desc">Send a message to potential roommates directly and get to know
                        them before committing.</p>
                </div>
                <div class="lp-how-card reveal">
                    <div class="lp-how-num">04</div>
                    <div class="lp-how-icon"><i class="fa-solid fa-key"></i></div>
                    <div class="lp-how-title">Move In</div>
                    <p class="lp-how-desc">Finalize your arrangement, sign your lease, and settle into your
                        new home with confidence.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- FEATURED LISTINGS -->
    <section id="listings">
        <div class="container">
            <div class="lp-row-head">
                <div class="lp-section-head lp-left reveal">
                    <div class="lp-eyebrow lp-text-only">Rooms &amp; Apartments</div>
                    <h2 class="lp-section-title">Featured Listings</h2>
                </div>
                <a href="/listings" class="lp-view-link reveal">View all listings →</a>
            </div>

            <div class="lp-cards-row">
                <div class="lp-listing-card reveal">
                    <div class="lp-card-img-wrap">
                        <img src="https://picsum.photos/seed/roomiefinder-room1/500/400.webp" alt="Bright room in modern flat">
                        <div class="lp-card-tag">Available Now</div>
                        <button class="lp-card-fav listing-fav">♡</button>
                    </div>
                    <div class="lp-card-body">
                        <div class="lp-card-title-row">
                            <div class="lp-card-title">Bright Room in Modern Flat</div>
                            <div class="lp-card-price">$780<span>/mo</span></div>
                        </div>
                        <div class="lp-card-loc"><i class="fa-solid fa-location-dot"></i> Brooklyn, NY</div>
                        <div class="lp-card-room"><i class="fa-solid fa-bed"></i> 1 private room</div>
                        <div class="lp-card-chips">
                            <span class="lp-chip">Utilities included</span>
                            <span class="lp-chip">Non-smoker</span>
                        </div>
                    </div>
                </div>

                <div class="lp-listing-card reveal">
                    <div class="lp-card-img-wrap">
                        <img src="https://picsum.photos/seed/roomiefinder-room2/500/400.webp" alt="Cozy loft near campus">
                        <div class="lp-card-tag">From Aug 1</div>
                        <button class="lp-card-fav listing-fav">♡</button>
                    </div>
                    <div class="lp-card-body">
                        <div class="lp-card-title-row">
                            <div class="lp-card-title">Cozy Loft Near Campus</div>
                            <div class="lp-card-price">$650<span>/mo</span></div>
                        </div>
                        <div class="lp-card-loc"><i class="fa-solid fa-location-dot"></i> Austin, TX</div>
                        <div class="lp-card-room"><i class="fa-solid fa-bed"></i> 1 shared room</div>
                        <div class="lp-card-chips">
                            <span class="lp-chip">Student-friendly</span>
                            <span class="lp-chip">Pet-friendly</span>
                        </div>
                    </div>
                </div>

                <div class="lp-listing-card reveal">
                    <div class="lp-card-img-wrap">
                        <img src="https://picsum.photos/seed/roomiefinder-room3/500/400.webp" alt="Sunny studio in midtown">
                        <div class="lp-card-tag">Available Now</div>
                        <button class="lp-card-fav listing-fav">♡</button>
                    </div>
                    <div class="lp-card-body">
                        <div class="lp-card-title-row">
                            <div class="lp-card-title">Sunny Studio in Midtown</div>
                            <div class="lp-card-price">$1,100<span>/mo</span></div>
                        </div>
                        <div class="lp-card-loc"><i class="fa-solid fa-location-dot"></i> Chicago, IL</div>
                        <div class="lp-card-room"><i class="fa-solid fa-bed"></i> 1 studio</div>
                        <div class="lp-card-chips">
                            <span class="lp-chip">Gym access</span>
                            <span class="lp-chip">Rooftop</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ROOMMATE PROFILES -->
    <section id="roommates">
        <div class="container">
            <div class="lp-row-head">
                <div class="lp-section-head lp-left reveal">
                    <div class="lp-eyebrow lp-text-only">Roommate Profiles</div>
                    <h2 class="lp-section-title">Find Compatible Roommates</h2>
                </div>
                <a href="#roommates" class="lp-view-link reveal">Browse all profiles →</a>
            </div>

            <div class="lp-roommates-row">
                <div class="lp-profile-card reveal">
                    <div class="lp-profile-top">
                        <div class="lp-profile-id">
                            <div class="lp-avatar-circle">SK</div>
                            <div>
                                <div class="lp-profile-name">Sarah Kim</div>
                                <div class="lp-profile-role">UX Designer</div>
                            </div>
                        </div>
                        <div class="lp-match-badge">94% match</div>
                    </div>
                    <div class="lp-profile-meta">
                        <div><i class="fa-solid fa-location-dot"></i> San Francisco, CA</div>
                        <div><i class="fa-solid fa-dollar-sign"></i> $900–$1,200</div>
                    </div>
                    <div class="lp-profile-tags">
                        <span class="lp-chip">Early bird</span>
                        <span class="lp-chip">Vegetarian</span>
                        <span class="lp-chip">Neat</span>
                    </div>
                    <button class="lp-btn-view-profile">View Profile</button>
                </div>

                <div class="lp-profile-card reveal">
                    <div class="lp-profile-top">
                        <div class="lp-profile-id">
                            <div class="lp-avatar-circle">ML</div>
                            <div>
                                <div class="lp-profile-name">Marcus Lee</div>
                                <div class="lp-profile-role">Software Engineer</div>
                            </div>
                        </div>
                        <div class="lp-match-badge">88% match</div>
                    </div>
                    <div class="lp-profile-meta">
                        <div><i class="fa-solid fa-location-dot"></i> Austin, TX</div>
                        <div><i class="fa-solid fa-dollar-sign"></i> $700–$1,000</div>
                    </div>
                    <div class="lp-profile-tags">
                        <span class="lp-chip">Night owl</span>
                        <span class="lp-chip">Gamer</span>
                        <span class="lp-chip">Non-smoker</span>
                    </div>
                    <button class="lp-btn-view-profile">View Profile</button>
                </div>

                <div class="lp-profile-card reveal">
                    <div class="lp-profile-top">
                        <div class="lp-profile-id">
                            <div class="lp-avatar-circle">ET</div>
                            <div>
                                <div class="lp-profile-name">Elena Torres</div>
                                <div class="lp-profile-role">Graduate Student</div>
                            </div>
                        </div>
                        <div class="lp-match-badge">91% match</div>
                    </div>
                    <div class="lp-profile-meta">
                        <div><i class="fa-solid fa-location-dot"></i> Chicago, IL</div>
                        <div><i class="fa-solid fa-dollar-sign"></i> $600–$850</div>
                    </div>
                    <div class="lp-profile-tags">
                        <span class="lp-chip">Quiet</span>
                        <span class="lp-chip">Book lover</span>
                        <span class="lp-chip">Vegan</span>
                    </div>
                    <button class="lp-btn-view-profile">View Profile</button>
                </div>
            </div>
        </div>
    </section>

    <!-- TESTIMONIALS / STORIES -->
    <section id="reviews" class="lp-stories-section">
        <div class="container">
            <div class="lp-section-head reveal">
                <div class="lp-eyebrow"><i class="fa-regular fa-heart"></i> Real stories</div>
                <h2 class="lp-section-title">Thousands Found Their Match</h2>
                <p class="lp-section-sub">Don't take our word for it — here's what our community says.</p>
            </div>

            <div class="lp-testi-row">
                <div class="lp-testi-card reveal">
                    <div class="lp-stars">★★★★★</div>
                    <p class="lp-testi-text">"I found my roommate in less than a week! The compatibility
                        matching is genuinely impressive — we have so much in common."</p>
                    <div class="lp-testi-author">
                        <div class="lp-testi-avatar">AS</div>
                        <div>
                            <div class="lp-testi-name">Anika Sharma</div>
                            <div class="lp-testi-role">Grad Student, Boston</div>
                        </div>
                    </div>
                </div>
                <div class="lp-testi-card reveal">
                    <div class="lp-stars">★★★★★</div>
                    <p class="lp-testi-text">"RoomieFinder saved me so much time. The filters are spot-on
                        and I never had to deal with sketchy listings."</p>
                    <div class="lp-testi-author">
                        <div class="lp-testi-avatar">JH</div>
                        <div>
                            <div class="lp-testi-name">Jordan Hayes</div>
                            <div class="lp-testi-role">Software Dev, Seattle</div>
                        </div>
                    </div>
                </div>
                <div class="lp-testi-card reveal">
                    <div class="lp-stars">★★★★★</div>
                    <p class="lp-testi-text">"Moving to a new city was scary, but finding a roommate
                        through here made it feel so much easier. Highly recommend."</p>
                    <div class="lp-testi-author">
                        <div class="lp-testi-avatar">MW</div>
                        <div>
                            <div class="lp-testi-name">Mei-Ling Wu</div>
                            <div class="lp-testi-role">Marketing Manager, NYC</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="lp-stats-row">
                <div class="lp-stat-card reveal">
                    <div class="lp-stat-num">50,000+</div>
                    <div class="lp-stat-label">Successful matches</div>
                </div>
                <div class="lp-stat-card reveal">
                    <div class="lp-stat-num">120 cities</div>
                    <div class="lp-stat-label">Across the US</div>
                </div>
                <div class="lp-stat-card reveal">
                    <div class="lp-stat-num">4.9★</div>
                    <div class="lp-stat-label">Average rating</div>
                </div>
                <div class="lp-stat-card reveal">
                    <div class="lp-stat-num">&lt; 7 days</div>
                    <div class="lp-stat-label">Avg. time to match</div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section style="padding: 90px 0;">
        <div class="lp-cta-band reveal">
            <div>
                <h2>Ready to Find Your Perfect Home?</h2>
                <p>Join over 50,000 people who found their ideal living situation.</p>
            </div>
            <div class="lp-cta-buttons">
                <a href="/listings"><button class="lp-btn-white">Find a Room</button></a>
                <a href="#roommates"><button class="lp-btn-outline-white">Find a Roommate</button></a>
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <footer class="lp-footer">
        <div class="container">
            <div class="lp-footer-grid">
                <div class="lp-footer-brand">
                    <div class="lp-brand">
                        <div class="lp-brand-mark">R</div>
                        RoomieFinder
                    </div>
                    <p class="lp-footer-tagline">Helping people find compatible roommates and shared living
                        spaces since 2020.</p>
                </div>
                <div class="lp-footer-col">
                    <h5>Product</h5>
                    <a href="/listings">Browse Rooms</a>
                    <a href="#roommates">Find Roommates</a>
                    <a href="#how">How It Works</a>
                    <a href="#reviews">Reviews</a>
                </div>
                <div class="lp-footer-col">
                    <h5>Company</h5>
                    <a href="#">About Us</a>
                    <a href="#">Blog</a>
                    <a href="#">Careers</a>
                    <a href="#">Contact</a>
                </div>
                <div class="lp-footer-col">
                    <h5>Legal</h5>
                    <a href="#">Privacy Policy</a>
                    <a href="#">Terms of Service</a>
                    <a href="#">Cookie Policy</a>
                </div>
            </div>
            <div class="lp-footer-bottom">
                <div class="lp-footer-copy">© 2026 RoomieFinder. All rights reserved.</div>
                <div class="lp-footer-socials">
                    <a href="#">𝕏</a>
                    <a href="#">in</a>
                    <a href="#">ig</a>
                </div>
            </div>
        </div>
    </footer>

</div>

<%- include('auth/login') %>
<%- include('auth/register') %>

    <script src="/js/main.js"></script>
</body>

</html>
