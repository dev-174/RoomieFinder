<%- include('../partials/header', { 
    title: title, 
    currentPage: currentPage,
    currentUser: null 
}) %>

<h1>All Room Listings</h1>

<div class="search-bar">
    <input type="text" id="searchInput" class="search-input" 
           placeholder="Search by location..." 
           onkeyup="filterListings()">
    <button class="btn btn-primary">🔍 Search</button>
</div>

<% if (listings.length > 0) { %>
    <div class="listings-grid">
        <% listings.forEach(listing => { %>
            <div class="listing-card">
                <div class="listing-content">
                    <h3 class="listing-title"><%= listing.title %></h3>
                    <p class="listing-price">₹<%= listing.price %>/month</p>
                    <p class="listing-location">📍 <%= listing.location %></p>
                    <a href="/listings/<%= listing.id %>" class="btn btn-primary">View Details</a>
                </div>
            </div>
        <% }) %>
    </div>
<% } else { %>
    <div class="alert alert-info">
        No listings available yet. <a href="/listings/new">Post your first room</a>!
    </div>
<% } %>

<%- include('../partials/footer') %>